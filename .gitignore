# Session handoff artifacts are local-only; do not track in the repository.
thoughts/shared/handoffs/

# Local Sonar opt-out: credential-scan skip markers and plugin-disable settings.
.claude/.sonar-skip
.claude/settings.json

# Build output: Directory.Build.props consolidates every project under build/
# (build/bin for binaries, build/obj for intermediates).
/build/

# Legacy/stray MSBuild output directories from earlier layouts (pre-build/ migration).
/bin/
/obj/
/Release/
/Debug/

# Stale / legacy in-tree MSBuild output and editor state.
source/x64/
source/Release/
source/Debug/
source/**/x64/
source/**/Intermediate/
*.sdf
*.suo
*.VC.db
*.stackdump
bash.exe.stackdump
/source/.vs
